{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "web",
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "static-out",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["-y", "serve", "out", "-l", "5050"],
      "cwd": "web",
      "port": 5050,
      "autoPort": true
    }
  ]
}
